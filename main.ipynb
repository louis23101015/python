import pandas as pd
import requests
import plotly
import plotly.graph_objects as go
import json

file_path = "법정구역_시군구.geojson"
try:
    with open(file_path, 'r', encoding='utf-8') as f:
        geojson = json.load(f)
except UnicodeDecodeError:
    with open(file_path, 'r', encoding='cp949') as f:
        geojson = json.load(f)

url = 'http://apis.data.go.kr/B552584/ArpltnInforInqireSvc/getCtprvnRltmMesureDnsty'
api_key = 'e6acd91356c2d58e97892cb61d5a0ec7613456f65081e7bedebeaf0ee84eeff3'
params = {
    'serviceKey' : api_key,
    'returnType' : 'json',
    'numOfRows' : '100',
    'pageNo' : '1',
    'itemCode' : 'PM10',
    'sidoName' : '전국',
    'ver' : '1.0'
}



response = requests.get(url, params=params)
data = response.json()
print(response.status_code)
print(response.text)

items = response.json()['response']['body']['items']
df = pd.DataFrame(data['response']['body']['items'])

geojson_names = [feature['properties']['SIG_KOR_NM'] for feature in geojson['features']]

def map_station_to_sig(row):
    sido = row['sidoName']
    station = row['stationName']

    # 전남 지역 예외 처리
    if sido == '전남':
        if '중마' in station: return '광양시'
        if '율촌' in station: return '여수시' # 율촌 측정소는 여수/광양 경계이나 보통 여수 관리
        if '광양' in station: return '광양시'

    # 경기 지역 예외 처리 (예시)
    if sido == '경기':
        if '백석' in station: return '양주시'

    # 기본적으로 이름 뒤에 '시'나 '구'가 없으면 붙여주는 보조 로직
    if not station.endswith(('시', '군', '구')):
        # 실제로는 여기서 시군구 목록과 대조하는 과정이 있으면 더 좋습니다.
        return station + '시'

    return station

df['changed_name'] = df.apply(map_station_to_sig, axis=1)

print(df['changed_name'])

fig = go.Figure(data=go.Choropleth(geojson=geojson,
                                   featureidkey="properties.SIG_KOR_NM",
                                   locations=df['changed_name'],
                                   z=df['pm10Value'],
                                   hovertext= df['changed_name']+ ' ' + df['pm10Value'].apply(lambda x: f'{x:} ㎍/㎥'),
                                   hoverinfo='text',
                                   marker_line_color = '#555',
                                   marker_line_width=1,))

fig.update_layout(geo=dict(fitbounds="geojson",
                           visible=False,
                           showframe=False,
                           projection_type='mercator',
                           ),
                  margin={"r": 0, "t": 0, "l": 0, "b": 0},
                  )

fig.show()









